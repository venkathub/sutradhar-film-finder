data/artifacts/
# MLflow artifact store (self-hosted compose service, DEC-P3-2; runs referenced by id).
data/mlflow-artifacts/
*.duckdb
*.sqlite

# Vector store / DB volumes
qdrant_storage/
pgdata/

# Editor / OS
.idea/
.vscode/
.DS_Store
*.log

# Vitest browser-mode failure screenshots (debris, not evidence)
__screenshots__/

# Playwright demo-video recordings (published as Release assets, never committed)
demo-video/
