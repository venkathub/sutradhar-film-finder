# Sutradhar — environment template. Copy to `.env` and fill in secrets.
#   cp .env.example .env
# No real secret belongs in this file or in code. `.env` is git-ignored; `.env.example` is tracked.
# Every value here is read exactly once by src/sutradhar/config/settings.py (the only env reader).

# ---------------------------------------------------------------------------
# LLM endpoint (on-demand vLLM on the rented GPU; normally OFF / paused).
# Reached via an env-driven URL — either the JarvisLabs instance URL or an SSH
# tunnel to the instance: `ssh -L 8000:localhost:8000 <instance>` → localhost:8000/v1.
# Never hardcode the endpoint or model id anywhere in code.
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:8000/v1
# DEC-0001: base = google/gemma-4-E4B (fallback Qwen/Qwen3-4B-Instruct-2507).
LLM_MODEL=google/gemma-4-E4B
# vLLM --api-key bearer; "EMPTY" when the server runs without auth.
LLM_API_KEY=EMPTY
# Client timeout (seconds) for the connectivity smoke call.
LLM_TIMEOUT_S=10

# ---------------------------------------------------------------------------
# Retrieval models (DEC-0002 pins) — env defaults only; not loaded until P2.
# ---------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# P5 live embedding path (OpenAI-compatible /v1/embeddings on the on-demand GPU).
# Leave unset in P2: the laptop/CI retrieval path reads recorded artifacts only.
EMBED_BASE_URL=
# Pinned retrieval-artifact run id (directory under data/artifacts/retrieval/) that
# `make load-index` / `make rag-demo` / CI read. Set after the P2 GPU embed session.
RETRIEVAL_RUN=

# ---------------------------------------------------------------------------
# Postgres (+pgvector) — matches infra/docker-compose.yml dev defaults.
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sutradhar
POSTGRES_USER=sutradhar
POSTGRES_PASSWORD=sutradhar

# ---------------------------------------------------------------------------
# Redis (optional cache).
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Hugging Face Hub — required for `make hf-check` (whoami) and P4 artifact push.
# Use a MODERN token (huggingface_hub v1.0 needs an API-v2 token; legacy tokens 401).
# ---------------------------------------------------------------------------
HF_TOKEN=
# DEC-P2-7 HF-relay for GPU jobs: PRIVATE dataset repo (e.g. <user>/sutradhar-artifacts)
# that ferries gpu_inputs.json + the job script up and sealed artifact runs back.
# Use a fine-grained token scoped to THIS repo: `make gpu-embed` embeds it in the
# instance startup script (removed with the script slot at teardown).
HF_ARTIFACT_REPO=

# ---------------------------------------------------------------------------
# JarvisLabs on-demand GPU — required for `make gpu-validate`
# (ephemeral create -> serve -> smoke -> destroy). GPU_TYPE per DEC-0003.
# ---------------------------------------------------------------------------
JARVISLABS_API_KEY=
GPU_TYPE=A100

# ---------------------------------------------------------------------------
# TMDB — unused until P1 (data ingestion).
# ---------------------------------------------------------------------------
TMDB_API_KEY=

# ---------------------------------------------------------------------------
# Data-source endpoints (P1 ingestion) — override only for testing/mirrors.
# HTTP_USER_AGENT: WMF User-Agent policy wants a descriptive UA with contact info;
# set your own fork URL / contact when running ingestion.
# ---------------------------------------------------------------------------
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
TMDB_API_URL=https://api.themoviedb.org/3
IMDB_DATASETS_URL=https://datasets.imdbws.com
WIKIPEDIA_API_URL=https://{lang}.wikipedia.org/w/api.php
HTTP_USER_AGENT=SutradharBot/0.1 (https://github.com/sutradhar/sutradhar; data-pipeline)

# ---------------------------------------------------------------------------
# Langfuse tracing — unused until P3.
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
