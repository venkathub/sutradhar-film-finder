# Sutradhar — environment template. Copy to `.env` and fill in secrets.
#   cp .env.example .env
# No real secret belongs in this file or in code. `.env` is git-ignored; `.env.example` is tracked.
# Every value here is read exactly once by src/sutradhar/config/settings.py (the only env reader).

# ---------------------------------------------------------------------------
# LLM endpoint (on-demand vLLM on the rented GPU; normally OFF / paused).
# Reached via an env-driven URL — either the JarvisLabs instance URL or an SSH
# tunnel to the instance: `ssh -L 8000:localhost:8000 <instance>` → localhost:8000/v1.
# Never hardcode the endpoint or model id anywhere in code.
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://localhost:8000/v1
# DEC-0001 (corrected DEC-P4-9): base = google/gemma-4-E4B-it @ fee6332c1abaafb77f6f96
# (fallback Qwen/Qwen3-4B-Instruct-2507). P4 adapter (verdict CUT, kept for provenance):
# venkat2393/sutradhar-gemma4-e4b-qlora-v1.
LLM_MODEL=google/gemma-4-E4B-it
# vLLM --api-key bearer; "EMPTY" when the server runs without auth.
LLM_API_KEY=EMPTY
# Client timeout (seconds) for the connectivity smoke call.
LLM_TIMEOUT_S=10

# ---------------------------------------------------------------------------
# Retrieval models (DEC-0002 pins) — env defaults only; not loaded until P2.
# ---------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# P5 live embedding path (OpenAI-compatible /v1/embeddings on the on-demand GPU).
# Leave unset in P2: the laptop/CI retrieval path reads recorded artifacts only.
EMBED_BASE_URL=
# Pinned retrieval-artifact run id (directory under data/artifacts/retrieval/) that
# `make load-index` / `make rag-demo` / CI read. Set after the P2 GPU embed session.
RETRIEVAL_RUN=

# ---------------------------------------------------------------------------
# Postgres (+pgvector) — matches infra/docker-compose.yml dev defaults.
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sutradhar
POSTGRES_USER=sutradhar
POSTGRES_PASSWORD=sutradhar

# ---------------------------------------------------------------------------
# Redis (optional cache).
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Hugging Face Hub — required for `make hf-check` (whoami) and P4 artifact push.
# Use a MODERN token (huggingface_hub v1.0 needs an API-v2 token; legacy tokens 401).
# ---------------------------------------------------------------------------
HF_TOKEN=
# DEC-P2-7 HF-relay for GPU jobs: PRIVATE dataset repo (e.g. <user>/sutradhar-artifacts)
# that ferries gpu_inputs.json + the job script up and sealed artifact runs back.
# Use a fine-grained token scoped to THIS repo: `make gpu-embed` embeds it in the
# instance startup script (removed with the script slot at teardown).
HF_ARTIFACT_REPO=

# ---------------------------------------------------------------------------
# JarvisLabs on-demand GPU — required for `make gpu-validate`
# (ephemeral create -> serve -> smoke -> destroy). GPU_TYPE per DEC-0003.
# ---------------------------------------------------------------------------
JARVISLABS_API_KEY=
GPU_TYPE=A100
# vLLM flags for serving the model under test (tool calling REQUIRES the model-family
# parser — Gemma 4 = gemma4; without it every tools request 400s, found live 2026-07-04).
VLLM_SERVE_FLAGS=--enable-auto-tool-choice --tool-call-parser gemma4 --reasoning-parser gemma4
# Instance disk (GB). The P4 teacher session self-raises this to >=150 (Sarvam-M bf16
# download before on-the-fly fp8 quantization); other sessions are fine at 80.
GPU_STORAGE_GB=80

# ---------------------------------------------------------------------------
# P5 serving — FastAPI orchestration + on-demand GPU serve session (P5_SPEC §2.2).
# RERANK_BASE_URL mirrors EMBED_BASE_URL: set only while a GPU serve window is up
# (printed by `make gpu-serve`); unset = graceful GPU-off degradation, never an error.
# GPU_HOURLY_USD = A100 40GB rate (DEC-0003) feeding token/cost/latency accounting.
# ---------------------------------------------------------------------------
RERANK_BASE_URL=
API_PORT=8080
SESSION_TTL_S=3600
GPU_HOURLY_USD=0.89
SERVE_HOLD_MINUTES=60

# ---------------------------------------------------------------------------
# P6 UI & portfolio surface (P6_SPEC §2.2). DEMO_VIDEO_URL = the recorded demo
# video (GitHub Release asset, DEC-P6-3); blank until the rehearsal window ⇒
# the offline payload omits the link (never a dead link). SITE_BASE_URL = the
# static always-available surface (GitHub Pages); docs/link-check use only.
# ---------------------------------------------------------------------------
DEMO_VIDEO_URL=
SITE_BASE_URL=

# ---------------------------------------------------------------------------
# TMDB — unused until P1 (data ingestion).
# ---------------------------------------------------------------------------
TMDB_API_KEY=

# ---------------------------------------------------------------------------
# Data-source endpoints (P1 ingestion) — override only for testing/mirrors.
# HTTP_USER_AGENT: WMF User-Agent policy wants a descriptive UA with contact info;
# set your own fork URL / contact when running ingestion.
# ---------------------------------------------------------------------------
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
TMDB_API_URL=https://api.themoviedb.org/3
IMDB_DATASETS_URL=https://datasets.imdbws.com
WIKIPEDIA_API_URL=https://{lang}.wikipedia.org/w/api.php
HTTP_USER_AGENT=SutradharBot/0.1 (https://github.com/sutradhar/sutradhar; data-pipeline)

# ---------------------------------------------------------------------------
# Langfuse tracing — P3 (DEC-P3-6/DEC-P3-7). Blank keys => tracing no-ops
# (Tier-1 CI / forks). Backend: self-hosted Langfuse v3 on the AIC Cloud VPS
# (`make langfuse-up`); Langfuse Cloud free tier is the documented fallback.
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
# AIC Cloud API key (dashboard -> Settings -> API Keys) for `make langfuse-up`
# (DEC-P3-7 idempotent VPS bootstrap). Razorpay payment legs stay browser-only.
AICCLOUD_API_KEY=

# ---------------------------------------------------------------------------
# MLflow tracking + registry — self-hosted compose service (P3, DEC-P3-2).
# Backend store = the compose Postgres (separate `mlflow` database); artifacts
# under ./data/mlflow-artifacts/. Start with `make mlflow-up`.
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# ---------------------------------------------------------------------------
# LLM-as-judge endpoint (P3, DEC-P3-1) — the pinned cross-family OSS judge
# served by vLLM in a short ephemeral GPU session (frontier API only as the
# documented escalation; A<->B is pure config, never code). Blank => judge-
# dependent steps skip cleanly (same first-class "off" posture as the smoke).
# ---------------------------------------------------------------------------
JUDGE_BASE_URL=
JUDGE_MODEL=
JUDGE_API_KEY=

# Pinned generation-run artifact id (evals/generation_runs/<run_id>.json) that
# Tier-1 CI regression-gates on between GPU windows (DEC-P2-6 posture). Blank =>
# the committed evals/generation_runs/PINNED_RUN file (the live P4 BASE column,
# 20260704T093206Z-e9598564) > latest artifact. Dry-run machinery evidence:
# 20260703T012339Z-e7fff041 (never published to Table 2).
GENERATION_RUN=

# ---------------------------------------------------------------------------
# Synthetic-data teacher endpoint (P4, DEC-P4-1) — Sarvam-M 24B self-hosted on
# the ephemeral GPU (8-bit weight-only via vLLM; `sarvamai/sarvam-m`), reached
# through the same OpenAI-compatible client contract as the LLM/judge. The
# recorded escalation (frontier API, DEC-P4-1 trigger only) is the same three
# vars with different values — config, never code. Blank => teacher-dependent
# steps skip cleanly (scaffold-only builds still work).
# ---------------------------------------------------------------------------
TEACHER_BASE_URL=
TEACHER_MODEL=
TEACHER_API_KEY=

# ---------------------------------------------------------------------------
# Fine-tune artifacts on HF Hub (P4, DEC-P4-7). Adapter repo is public at
# publish time (e.g. <user>/sutradhar-gemma4-e4b-qlora-v1); the dataset repo
# stays PRIVATE-first (e.g. <user>/sutradhar-ft-v1) pending the LICENSING.md
# review (IMDb-derived AKA titles). FT_DATASET_ID stamps the card + sealed
# JSONL; CI only ever reads the committed in-repo sample, never the Hub.
# ---------------------------------------------------------------------------
HF_ADAPTER_REPO=
FT_DATASET_REPO=
FT_DATASET_ID=sutradhar-ft-v1
